<configuration>
    <appender name="client_log" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/client.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/archived/client-%d{yyyy-MM-dd_HH-mm}.%i.log</fileNamePattern>

            <maxFileSize>5MB</maxFileSize>

            <maxHistory>1500</maxHistory>

            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="client_log" />
    </root>
</configuration>