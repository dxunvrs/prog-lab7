<configuration>
    <appender name="client_log" class="ch.qos.logback.core.FileAppender">
        <file>logs/client.log</file>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="TRACE">
        <appender-ref ref="client_log" />
    </root>
</configuration>